# VERIDIA Environment Variables
# Copy this file to .env.local and fill in values

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VERIDIA

# ── Helius (REQUIRED for live on-chain verification) ─────────────────────────
# Get a free key at https://helius.dev (100K credits/month free tier)
HELIUS_API_KEY=your-helius-api-key-here

# ── GitHub (OPTIONAL — raises rate limit from 60 to 5000 req/hr) ─────────────
# Create at https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=your-github-token-here

# ── Solana RPC ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
